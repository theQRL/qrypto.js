{
  "name": "root",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "turbo run build",
    "test": "FORCE_COLOR=0 turbo test",
    "test:browser": "playwright install chromium && turbo run test:browser",
    "check-shared": "node scripts/check-shared-files.js",
    "lint": "turbo lint-check",
    "lint:fix": "turbo lint",
    "coverage": "turbo coverage",
    "report-coverage": "turbo report-coverage"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.4.0",
    "minimatch": "10.2.4",
    "multi-semantic-release": "3.1.0",
    "playwright": "1.58.2",
    "serialize-javascript": "7.0.4",
    "tar": "7.5.11",
    "turbo": "2.9.7"
  },
  "overrides": {
    "serialize-javascript": "7.0.4",
    "minimatch": "10.2.4",
    "tar": "7.5.11",
    "diff": "8.0.3",
    "**": {
      "serialize-javascript": "7.0.4",
      "minimatch": "10.2.4",
      "tar": "7.5.11",
      "diff": "8.0.3"
    }
  }
}
